DJANGO_SECRET_KEY=unsafe-default-key-for-dev # A secret key for a particular Django installation. This is used to provide cryptographic signing, and should be set to a unique, unpredictable value.
SPOTIFY_CLIENT_ID=your_spotify_client_id # Client ID from Spotify Developer Dashboard
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret # Client Secret from Spotify Developer Dashboard
FIREBASE_PROJECT_ID=your_firebase_project_id # Project ID from Firebase Console
FIREBASE_API_KEY=your_firebase_api_key # API Key from Firebase Console (used for REST authentication verification)
